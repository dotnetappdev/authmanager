@page "/authmanager/sessions"
@rendermode InteractiveServer
@inject ISessionService SessionService
@inject IAuditService AuditService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Active Sessions — Auth Manager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h4">Active Sessions</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_totalCount active session@(_totalCount == 1 ? "" : "s") — view and revoke live user sessions
        </MudText>
    </div>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.LogoutOutlined"
                   OnClick="RevokeAllSessions"
                   Disabled="@(_totalCount == 0)">
            Revoke All
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                       OnClick="Refresh" Title="Refresh" />
    </MudStack>
</MudStack>

<MudCard Elevation="0" Class="am-card-border">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="SessionInfo"
                     Items="_sessions"
                     @ref="_grid"
                     Dense="true"
                     Hover="true"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                     ShowColumnOptions="true"
                     SortMode="SortMode.Single"
                     Loading="@_loading"
                     RowsPerPage="25"
                     Class="am-data-grid">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchText" Placeholder="Search by username or IP..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Immediate="true" DebounceInterval="300"
                              Class="mt-0" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </ToolBarContent>

            <Columns>
                <TemplateColumn T="SessionInfo" Title="User" SortBy="x => x.UserName">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Class="am-avatar-initial">
                                @GetInitials(context.Item.UserName)
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Item.UserName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.Item.UserId[..Math.Min(8, context.Item.UserId.Length)]…
                                </MudText>
                            </div>
                            @if (context.Item.IsCurrent)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Current</MudChip>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn T="SessionInfo" TProperty="string?" Property="x => x.IpAddress"
                                Title="IP Address" Sortable="true">
                    <CellTemplate>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@(context.Item.IpAddress ?? "—")</MudText>
                            @if (!string.IsNullOrEmpty(context.Item.CountryCode))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.CountryCode</MudText>
                            }
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn T="SessionInfo" Title="Device / Browser" Sortable="false">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.UserAgent">
                            <MudText Typo="Typo.body2">
                                @(context.Item.DeviceDescription ?? TruncateUserAgent(context.Item.UserAgent))
                            </MudText>
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn T="SessionInfo" TProperty="DateTimeOffset" Property="x => x.CreatedAt"
                                Title="Started" Sortable="true" Filterable="false">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")">
                            <MudText Typo="Typo.body2">@FormatRelative(context.Item.CreatedAt)</MudText>
                        </MudTooltip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn T="SessionInfo" TProperty="DateTimeOffset" Property="x => x.LastActiveAt"
                                Title="Last Active" Sortable="true" Filterable="false">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.LastActiveAt.ToString("yyyy-MM-dd HH:mm:ss UTC")">
                            <MudText Typo="Typo.body2">@FormatRelative(context.Item.LastActiveAt)</MudText>
                        </MudTooltip>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn T="SessionInfo" Title="Expires" Sortable="false" Filterable="false">
                    <CellTemplate>
                        @if (context.Item.ExpiresAt.HasValue)
                        {
                            var expired = context.Item.ExpiresAt.Value < DateTimeOffset.UtcNow;
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(expired ? Color.Error : Color.Default)"
                                     Variant="Variant.Outlined">
                                @(expired ? "Expired" : FormatRelative(context.Item.ExpiresAt.Value))
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn T="SessionInfo" Title="Actions" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                           Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                           Title="Revoke this session"
                                           OnClick="@(() => RevokeSession(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.LogoutOutlined"
                                           Size="Size.Small" Color="Color.Error" Variant="Variant.Text"
                                           Title="Revoke all sessions for this user"
                                           OnClick="@(() => RevokeUserSessions(context.Item))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>
                <MudDataGridPager T="SessionInfo" />
            </PagerContent>

            <NoRecordsContent>
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.DesktopAccessDisabled" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary">No active sessions</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Sessions appear here once users sign in and
                        <code>ISessionService.TrackSessionAsync()</code> is called in your auth pipeline.
                    </MudText>
                </MudStack>
            </NoRecordsContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<SessionInfo> _grid = default!;
    private List<SessionInfo> _sessions = [];
    private int _totalCount;
    private bool _loading = true;
    private string _searchText = "";

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        _loading = true;
        _sessions = (await SessionService.GetAllSessionsAsync(1, 500)).ToList();
        _totalCount = _sessions.Count;
        _loading = false;
    }

    private async Task RevokeSession(SessionInfo session)
    {
        await SessionService.RevokeSessionAsync(session.SessionId);

        await AuditService.RecordAsync(new AuditEntry
        {
            Action     = AuditActions.SessionRevoked,
            EntityType = "Session",
            EntityId   = session.SessionId,
            EntityName = session.UserName,
            NewValues  = new Dictionary<string, object?> { ["UserId"] = session.UserId },
            Success    = true
        });

        Snackbar.Add($"Session for {session.UserName} revoked.", Severity.Success);
        await Refresh();
    }

    private async Task RevokeUserSessions(SessionInfo session)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Revoke All Sessions",
            $"Sign out {session.UserName} from all devices? They will need to log in again.",
            yesText: "Revoke All", cancelText: "Cancel");

        if (confirm != true) return;

        await SessionService.RevokeAllUserSessionsAsync(session.UserId);

        await AuditService.RecordAsync(new AuditEntry
        {
            Action     = AuditActions.AllSessionsRevoked,
            EntityType = "User",
            EntityId   = session.UserId,
            EntityName = session.UserName,
            Success    = true
        });

        Snackbar.Add($"All sessions for {session.UserName} revoked.", Severity.Success);
        await Refresh();
    }

    private async Task RevokeAllSessions()
    {
        var confirm = await DialogService.ShowMessageBox(
            "Revoke ALL Sessions",
            "This will sign out every user from every device immediately. Continue?",
            yesText: "Revoke All", cancelText: "Cancel");

        if (confirm != true) return;

        var userIds = _sessions.Select(s => s.UserId).Distinct().ToList();
        foreach (var uid in userIds)
            await SessionService.RevokeAllUserSessionsAsync(uid);

        await AuditService.RecordAsync(new AuditEntry
        {
            Action     = AuditActions.AllSessionsRevoked,
            EntityType = "System",
            EntityId   = "all",
            NewValues  = new Dictionary<string, object?> { ["RevokedCount"] = _totalCount },
            Success    = true
        });

        Snackbar.Add($"All {_totalCount} sessions revoked.", Severity.Warning);
        await Refresh();
    }

    private static string GetInitials(string name) =>
        string.IsNullOrEmpty(name) ? "?" :
        name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();

    private static string TruncateUserAgent(string? ua) =>
        string.IsNullOrEmpty(ua) ? "Unknown" :
        ua.Length > 40 ? ua[..40] + "…" : ua;

    private static string FormatRelative(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.UtcNow - dt;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM dd HH:mm");
    }
}
