@inject IUserManagementService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-2">
            <MudAlert Severity="Severity.Warning">
                This will immediately reset the password for <strong>@UserName</strong>.
                The user will need to use the new password to log in.
            </MudAlert>

            <MudTextField @bind-Value="_newPassword"
                          Label="New Password"
                          Required="true"
                          InputType="@(_showPw ? InputType.Text : InputType.Password)"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPw ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="@(() => _showPw = !_showPw)" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirm Password"
                          Required="true"
                          InputType="@(_showPw ? InputType.Text : InputType.Password)"
                          Variant="Variant.Outlined"
                          Error="@(_newPassword != _confirmPassword && !string.IsNullOrEmpty(_confirmPassword))"
                          ErrorText="Passwords do not match" />

            <MudCheckBox T="bool" @bind-Value="_requireChange" Color="Color.Primary"
                         Label="Require user to change password on next login" />

            @if (_errors.Length > 0)
            {
                <MudAlert Severity="Severity.Error">@string.Join(", ", _errors)</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   OnClick="Reset"
                   Disabled="@(_saving || string.IsNullOrEmpty(_newPassword) || _newPassword != _confirmPassword)">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Reset Password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public string UserName { get; set; } = string.Empty;

    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _requireChange;
    private bool _showPw;
    private bool _saving;
    private string[] _errors = [];

    private async Task Reset()
    {
        _saving = true;
        _errors = [];
        var (success, errors) = await UserService.ResetPasswordAsync(new ResetPasswordDto
        {
            UserId = UserId,
            NewPassword = _newPassword,
            RequirePasswordChange = _requireChange
        });

        if (success)
        {
            Snackbar.Add("Password reset successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            _errors = errors;
        }
        _saving = false;
    }

    private void Cancel() => MudDialog.Cancel();
}
