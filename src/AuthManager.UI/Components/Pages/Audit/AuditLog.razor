@page "/authmanager/audit"
@rendermode InteractiveServer
@inject IAuditService AuditService

<PageTitle>Audit Log — Auth Manager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h4">Audit Log</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Track all administrative changes made via Auth Manager
        </MudText>
    </div>
</MudStack>

<MudCard Elevation="0" Class="am-card-border">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="AuditEntry"
                     ServerData="LoadServerData"
                     @ref="_grid"
                     Dense="true"
                     Hover="true"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                     ShowColumnOptions="true"
                     SortMode="SortMode.Single"
                     RowsPerPage="50"
                     Class="am-data-grid">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchText" Placeholder="Search actions, entities, users..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Immediate="true" DebounceInterval="400"
                              Class="mt-0" Variant="Variant.Outlined" Margin="Margin.Dense"
                              OnKeyUp="OnSearchKeyUp" />
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                               OnClick="@(() => _grid.ReloadServerData())" Title="Refresh" />
            </ToolBarContent>

            <Columns>
                <PropertyColumn T="AuditEntry" TProperty="DateTimeOffset" Property="x => x.Timestamp"
                                Title="Timestamp" Sortable="true" Filterable="false">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss UTC")">
                            <MudText Typo="Typo.body2">@context.Item.Timestamp.ToString("MMM dd, HH:mm")</MudText>
                        </MudTooltip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn T="AuditEntry" TProperty="string" Property="x => x.Action"
                                Title="Action" Sortable="true">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.Item.Action)"
                                 Variant="Variant.Outlined" Class="ma-0">
                            @FormatAction(context.Item.Action)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn T="AuditEntry" TProperty="string" Property="x => x.EntityType"
                                Title="Entity Type" Sortable="true" />

                <TemplateColumn T="AuditEntry" Title="Entity" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@(context.Item.EntityName ?? context.Item.EntityId)</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn T="AuditEntry" Title="Performed By" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(context.Item.PerformedByUserName ?? context.Item.PerformedByUserId ?? "System")
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn T="AuditEntry" Title="Result" Sortable="false" Filterable="false">
                    <CellTemplate>
                        @if (context.Item.Success)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                     Icon="@Icons.Material.Filled.CheckCircle" Variant="Variant.Text">Success</MudChip>
                        }
                        else
                        {
                            <MudTooltip Text="@context.Item.ErrorMessage">
                                <MudChip T="string" Size="Size.Small" Color="Color.Error"
                                         Icon="@Icons.Material.Filled.Cancel" Variant="Variant.Text">Failed</MudChip>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn T="AuditEntry" Title="IP Address" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.Item.IpAddress ?? "—")</MudText>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>
                <MudDataGridPager T="AuditEntry" />
            </PagerContent>

            <NoRecordsContent>
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary">No audit entries yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Changes made via Auth Manager will appear here.
                    </MudText>
                </MudStack>
            </NoRecordsContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<AuditEntry> _grid = default!;
    private string _searchText = "";

    private async Task<GridData<AuditEntry>> LoadServerData(GridState<AuditEntry> state)
    {
        var result = await AuditService.GetAuditLogAsync(state.Page + 1, state.PageSize);

        // Client-side search filter on the current page
        var items = string.IsNullOrWhiteSpace(_searchText)
            ? result.Items
            : result.Items.Where(e =>
                (e.Action?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.EntityType?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.EntityName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.EntityId?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.PerformedByUserName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();

        return new GridData<AuditEntry> { Items = items, TotalItems = result.TotalCount };
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs _) => await _grid.ReloadServerData();

    private static Color GetActionColor(string action) => action switch
    {
        var a when a.Contains("Deleted") || a.Contains("Removed") => Color.Error,
        var a when a.Contains("Created") || a.Contains("Added")   => Color.Success,
        var a when a.Contains("Updated") || a.Contains("Reset")   => Color.Warning,
        var a when a.Contains("Locked")                            => Color.Error,
        _                                                           => Color.Info
    };

    private static string FormatAction(string action) =>
        System.Text.RegularExpressions.Regex.Replace(action, "(\\B[A-Z])", " $1");
}
