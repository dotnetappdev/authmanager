@page "/authmanager/tokens"
@rendermode InteractiveServer
@inject IApiTokenService TokenService
@inject IUserManagementService UserService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>API Tokens — Auth Manager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <div>
        <MudText Typo="Typo.h4">API Tokens</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Long-lived personal access tokens — like GitHub PATs. Stored as SHA-256 hashes; the raw value is shown only once.
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate">
        New Token
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (!_tokens.Any())
{
    <MudCard Elevation="0" Class="am-card-border">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary">No API tokens yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Create long-lived tokens for machine-to-machine access — CI/CD pipelines, scripts, integrations.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreate" Class="mt-2">
                    Create your first token
                </MudButton>
            </MudStack>
        </MudCardContent>
    </MudCard>
}
else
{
    <MudCard Elevation="0" Class="am-card-border">
        <MudCardContent Class="pa-0">
            <MudTable T="ApiTokenDto" Items="_tokens" Dense="true" Hover="true"
                      Elevation="0" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>User</MudTh>
                    <MudTh>Prefix</MudTh>
                    <MudTh>Scopes</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Last Used</MudTh>
                    <MudTh>Expires</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="User">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                            @(context.UserName ?? context.UserId)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Prefix">
                        <MudText Typo="Typo.caption" Style="font-family:monospace">@context.Prefix…</MudText>
                    </MudTd>
                    <MudTd DataLabel="Scopes">
                        @if (!string.IsNullOrWhiteSpace(context.Scopes))
                        {
                            @foreach (var s in context.Scopes.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mr-1">@s</MudChip>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">all</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsRevoked)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Revoked</MudChip>
                        }
                        else if (context.ExpiresAt.HasValue && context.ExpiresAt < DateTimeOffset.UtcNow)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Expired</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Active</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Last Used">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(context.LastUsedAt.HasValue ? context.LastUsedAt.Value.ToString("MMM dd, yyyy") : "Never")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Expires">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(context.ExpiresAt.HasValue ? context.ExpiresAt.Value.ToString("MMM dd, yyyy") : "Never")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                            @if (!context.IsRevoked)
                            {
                                <MudMenuItem OnClick="@(() => RevokeToken(context))">
                                    <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small" Class="mr-2" />Revoke
                                </MudMenuItem>
                            }
                            <MudMenuItem OnClick="@(() => DeleteToken(context))" Style="color:var(--mud-palette-error)">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Class="mr-2" />Delete
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>
}

<!-- ── Create Token Dialog ────────────────────────────────────────────────── -->
<MudDialog @bind-IsVisible="_showCreate" Options="_dialogOpts">
    <TitleContent>
        <MudText Typo="Typo.h6">New API Token</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name" Label="Token Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Placeholder="e.g. CI Pipeline, Deploy Bot" Required="true" />

            <MudSelect T="string" @bind-Value="_form.UserId" Label="Assign to User"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                @foreach (var u in _users)
                {
                    <MudSelectItem T="string" Value="@u.Id">@u.UserName (@u.Email)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_form.Scopes" Label="Scopes (space-separated, leave blank for all)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Placeholder="e.g. read:users write:roles" />

            <MudSelect T="int?" @bind-Value="_form.ExpiresInDays" Label="Expiry"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem T="int?" Value="@((int?)null)">Never expires</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)30)">30 days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)90)">90 days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)180)">180 days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)365)">1 year</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreate = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="CreateToken" Disabled="_saving">
            @(_saving ? "Creating…" : "Create Token")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ── Raw Token Reveal Dialog ───────────────────────────────────────────── -->
<MudDialog @bind-IsVisible="_showReveal" Options="_revealOpts">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Copy your token now</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            This token will <strong>never be shown again</strong>. Copy it now and store it securely.
        </MudAlert>
        <MudPaper Elevation="0" Class="am-card-border pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Style="font-family:monospace;word-break:break-all;flex:1">@_rawToken</MudText>
                <MudIconButton Icon="@(_copied ? Icons.Material.Filled.Check : Icons.Material.Filled.ContentCopy)"
                               Color="@(_copied ? Color.Success : Color.Default)"
                               Size="Size.Small"
                               Title="Copy to clipboard"
                               OnClick="CopyToken" />
            </MudStack>
        </MudPaper>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
            Store this in a secrets manager, environment variable, or password manager.
            Never commit it to source control.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => { _showReveal = false; _rawToken = null; _copied = false; })">
            I've saved it — close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ApiTokenDto> _tokens = [];
    private List<UserDto>     _users  = [];
    private bool _loading = true;
    private bool _saving;
    private bool _showCreate;
    private bool _showReveal;
    private bool _copied;
    private string? _rawToken;
    private readonly TokenFormModel _form = new();

    private static readonly DialogOptions _dialogOpts = new()
        { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };

    private static readonly DialogOptions _revealOpts = new()
        { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = false };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _tokens = await TokenService.GetTokensAsync();
        var page = await UserService.GetUsersAsync(new UserFilter { Page = 1, PageSize = 500 });
        _users  = page.Items;
    }

    private void OpenCreate()
    {
        _form.Name        = "";
        _form.UserId      = "";
        _form.Scopes      = "";
        _form.ExpiresInDays = null;
        _showCreate = true;
    }

    private async Task CreateToken()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        { Snackbar.Add("Token name is required.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_form.UserId))
        { Snackbar.Add("Please select a user.", Severity.Warning); return; }

        _saving = true;
        var (ok, errors, result) = await TokenService.CreateTokenAsync(new CreateApiTokenDto
        {
            Name         = _form.Name,
            UserId       = _form.UserId,
            Scopes       = string.IsNullOrWhiteSpace(_form.Scopes) ? null : _form.Scopes.Trim(),
            ExpiresInDays = _form.ExpiresInDays
        });
        _saving = false;

        if (ok && result is not null)
        {
            _showCreate = false;
            _rawToken   = result.RawToken;
            _copied     = false;
            _showReveal = true;
            await LoadAsync();
        }
        else
        {
            foreach (var e in errors)
                Snackbar.Add(e, Severity.Error);
        }
    }

    private async Task CopyToken()
    {
        if (_rawToken is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _rawToken);
        _copied = true;
        Snackbar.Add("Token copied to clipboard.", Severity.Success);
    }

    private async Task RevokeToken(ApiTokenDto token)
    {
        var (ok, errors) = await TokenService.RevokeTokenAsync(token.Id);
        if (ok) { Snackbar.Add($"Token '{token.Name}' revoked.", Severity.Success); await LoadAsync(); }
        else    foreach (var e in errors) Snackbar.Add(e, Severity.Error);
    }

    private async Task DeleteToken(ApiTokenDto token)
    {
        var (ok, errors) = await TokenService.DeleteTokenAsync(token.Id);
        if (ok) { Snackbar.Add($"Token '{token.Name}' deleted.", Severity.Success); await LoadAsync(); }
        else    foreach (var e in errors) Snackbar.Add(e, Severity.Error);
    }

    private sealed class TokenFormModel
    {
        public string  Name         { get; set; } = "";
        public string  UserId       { get; set; } = "";
        public string  Scopes       { get; set; } = "";
        public int?    ExpiresInDays { get; set; }
    }
}
