@page "/authmanager/oauth"
@rendermode InteractiveServer
@inject IOAuthProviderService OAuthService

<PageTitle>OAuth Providers — Auth Manager</PageTitle>

<div class="am-page-header">
    <div>
        <h1 class="am-page-title">OAuth Providers</h1>
        <p class="am-page-subtitle">Configure external identity providers for social login</p>
    </div>
</div>

@if (_loading)
{
    <Spinner />
}
else
{
    <div class="am-providers-grid">
        @foreach (var provider in _providers)
        {
            <div class="am-card am-provider-card">
                <div class="am-provider-header">
                    <div class="am-provider-logo am-provider-@provider.Name.ToLower()">
                        @switch (provider.Name)
                        {
                            case "Google":
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                                </svg>
                                break;
                            case "Microsoft":
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zM24 11.4H12.6V0H24v11.4z" fill="#F25022"/>
                                    <path d="M24 11.4H12.6V0H24v11.4z" fill="#7FBA00"/>
                                    <path d="M11.4 24H0V12.6h11.4V24z" fill="#00A4EF"/>
                                    <path d="M24 24H12.6V12.6H24V24z" fill="#FFB900"/>
                                </svg>
                                break;
                            case "Apple":
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                                </svg>
                                break;
                            case "GitHub":
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                                </svg>
                                break;
                            default:
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/>
                                    <circle cx="18" cy="19" r="3"/>
                                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                                </svg>
                                break;
                        }
                    </div>
                    <div class="am-provider-info">
                        <div class="am-provider-name">@provider.DisplayName</div>
                        <div class="am-provider-status">
                            @if (provider.IsEnabled && provider.IsConfigured)
                            {
                                <span class="am-badge am-badge-success">Active</span>
                            }
                            else if (provider.IsConfigured && !provider.IsEnabled)
                            {
                                <span class="am-badge am-badge-warning">Configured (Disabled)</span>
                            }
                            else
                            {
                                <span class="am-badge am-badge-ghost">Not Configured</span>
                            }
                        </div>
                    </div>
                    <button class="am-btn am-btn-sm @(provider.IsEnabled ? "am-btn-ghost" : "am-btn-primary")"
                            @onclick="@(() => EditProvider(provider))">
                        Configure
                    </button>
                </div>
                @if (provider.Settings.Count > 0)
                {
                    <div class="am-provider-settings">
                        @foreach (var (key, value) in provider.Settings)
                        {
                            <div class="am-provider-setting">
                                <span class="am-provider-setting-key">@key</span>
                                <span class="am-provider-setting-value">@(string.IsNullOrEmpty(value) ? "—" : value)</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

<Modal @ref="_modal" Title="Configure @_editingProvider?.DisplayName" Size="Modal.ModalSize.Large">
    <ChildContent>
        @if (_editingProvider != null)
        {
            <div class="am-form-group">
                <label class="am-switch-label">
                    <label class="am-switch">
                        <input type="checkbox" @bind="_editEnabled" />
                        <span class="am-switch-slider"></span>
                    </label>
                    Enable @_editingProvider.DisplayName login
                </label>
            </div>
            @foreach (var (key, value) in _editSettings)
            {
                var k = key;
                <div class="am-form-group">
                    <label class="am-label">@k</label>
                    <input class="am-input" type="@(k.Contains("Secret") || k.Contains("Key") ? "password" : "text")"
                           value="@value"
                           @onchange="@(e => _editSettings[k] = e.Value?.ToString() ?? "")"
                           placeholder="Enter @k..." />
                </div>
            }
        }
    </ChildContent>
    <FooterContent>
        <div class="am-modal-actions">
            <button class="am-btn am-btn-ghost" @onclick="@(_modal?.Close)">Cancel</button>
            <button class="am-btn am-btn-primary" @onclick="SaveProvider">Save</button>
        </div>
    </FooterContent>
</Modal>

@code {
    private List<OAuthProviderInfo> _providers = [];
    private bool _loading = true;
    private Modal? _modal;
    private OAuthProviderInfo? _editingProvider;
    private bool _editEnabled;
    private Dictionary<string, string> _editSettings = [];

    protected override async Task OnInitializedAsync()
    {
        _providers = await OAuthService.GetProvidersAsync();
        _loading = false;
    }

    private void EditProvider(OAuthProviderInfo provider)
    {
        _editingProvider = provider;
        _editEnabled = provider.IsEnabled;
        _editSettings = provider.Settings.ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
        _modal?.Open();
    }

    private async Task SaveProvider()
    {
        if (_editingProvider is null) return;
        var (success, errors) = await OAuthService.UpdateProviderAsync(new UpdateOAuthProviderDto
        {
            ProviderName = _editingProvider.Name,
            Enabled = _editEnabled,
            Settings = _editSettings
        });

        if (success)
        {
            ToastService.Instance.Success($"{_editingProvider.DisplayName} settings saved.");
            _modal?.Close();
            _providers = await OAuthService.GetProvidersAsync();
        }
        else
        {
            ToastService.Instance.Error(string.Join(", ", errors));
        }
    }
}
