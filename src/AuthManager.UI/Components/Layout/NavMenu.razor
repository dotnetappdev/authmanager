@inject NavigationManager Nav
@inject IOptions<AuthManagerOptions> Options
@inject IEntityNamingService Naming

<MudDrawer Open="true" Elevation="0" Variant="DrawerVariant.Persistent" ClipMode="DrawerClipMode.Always"
           Class="am-sidebar">
    <MudDrawerHeader Class="am-sidebar-brand" LinkToIndex="false">
        <div class="am-brand">
            <div class="am-brand-icon">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Size="Size.Large" />
            </div>
            <div class="am-brand-text">
                <div class="am-brand-name">@Options.Value.Title</div>
                <div class="am-brand-version">v1.0.0</div>
            </div>
        </div>
    </MudDrawerHeader>

    <MudNavMenu Class="am-nav">
        <MudText Typo="Typo.overline" Class="am-nav-section-label">Overview</MudText>
        <MudNavLink Href="@Prefix()" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
        <MudNavLink Href="@Prefix("health")" Icon="@Icons.Material.Filled.MonitorHeart">
            System Health
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Identity</MudText>
        <MudNavLink Href="@Prefix("users")" Icon="@Icons.Material.Filled.People">
            @Naming.GetUsersDisplayName()
        </MudNavLink>
        <MudNavLink Href="@Prefix("roles")" Icon="@Icons.Material.Filled.Stars">
            Roles
        </MudNavLink>
        <MudNavLink Href="@Prefix("groups")" Icon="@Icons.Material.Filled.Groups">
            Groups
        </MudNavLink>
        <MudNavLink Href="@Prefix("claims")" Icon="@Icons.Material.Filled.Badge">
            Claims
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Authentication</MudText>
        <MudNavLink Href="@Prefix("jwt")" Icon="@Icons.Material.Filled.Lock">
            JWT Settings
        </MudNavLink>
        <MudNavLink Href="@Prefix("oauth")" Icon="@Icons.Material.Filled.Share">
            OAuth Providers
        </MudNavLink>
        <MudNavLink Href="@Prefix("sso")" Icon="@Icons.Material.Filled.BusinessCenter">
            SSO / Entra ID
        </MudNavLink>
        <MudNavLink Href="@Prefix("otp")" Icon="@Icons.Material.Filled.Pin">
            One-Time Passwords
        </MudNavLink>
        <MudNavLink Href="@Prefix("sessions")" Icon="@Icons.Material.Filled.Devices">
            Active Sessions
        </MudNavLink>
        <MudNavLink Href="@Prefix("2fa")" Icon="@Icons.Material.Filled.PhonelinkLock">
            Two-Factor Auth
        </MudNavLink>
        <MudNavLink Href="@Prefix("tokens")" Icon="@Icons.Material.Filled.Key">
            API Tokens
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Messaging</MudText>
        <MudNavLink Href="@Prefix("email-settings")" Icon="@Icons.Material.Filled.MailOutline">
            Email Settings
        </MudNavLink>
        <MudNavLink Href="@Prefix("email-templates")" Icon="@Icons.Material.Filled.Description">
            Email Templates
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Customisation</MudText>
        <MudNavLink Href="@Prefix("userfields")" Icon="@Icons.Material.Filled.DynamicForm">
            User Fields
        </MudNavLink>
        <MudNavLink Href="@Prefix("settings")" Icon="@Icons.Material.Filled.Tune">
            Display Settings
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Security</MudText>
        <MudNavLink Href="@Prefix("security")" Icon="@Icons.Material.Filled.AdminPanelSettings">
            Security Settings
        </MudNavLink>

        <MudText Typo="Typo.overline" Class="am-nav-section-label">Observability</MudText>
        <MudNavLink Href="@Prefix("logs")" Icon="@Icons.Material.Filled.List">
            Log Viewer
        </MudNavLink>
        <MudNavLink Href="@Prefix("audit")" Icon="@Icons.Material.Filled.History">
            Audit Log
        </MudNavLink>
        <MudNavLink Href="@Prefix("signin-history")" Icon="@Icons.Material.Filled.Login">
            Sign-in History
        </MudNavLink>
    </MudNavMenu>

    <div class="am-sidebar-footer">
        <MudTooltip Text="@(IsDark ? "Switch to Light Mode" : "Switch to Dark Mode")">
            <MudIconButton Icon="@(IsDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="OnThemeToggle" />
        </MudTooltip>
    </div>
</MudDrawer>

@code {
    [Parameter] public bool IsDark { get; set; }
    [Parameter] public EventCallback OnThemeToggle { get; set; }

    private string Prefix(string? path = null)
    {
        var p = Options.Value.RoutePrefix.Trim('/');
        return string.IsNullOrEmpty(path) ? $"/{p}" : $"/{p}/{path}";
    }
}
