@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="am-setup-root">
    <div class="am-setup-bg"></div>

    <header class="am-setup-header">
        <div class="am-setup-brand">
            <svg class="am-setup-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="40" height="40" rx="10" fill="url(#setupGrad)" />
                <path d="M20 8 L28 14 V22 C28 27 24 31 20 33 C16 31 12 27 12 22 V14 Z"
                      fill="white" fill-opacity="0.9" />
                <path d="M17 21 L19 23 L23 19" stroke="#6D28D9" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round" />
                <defs>
                    <linearGradient id="setupGrad" x1="0" y1="0" x2="40" y2="40">
                        <stop offset="0%" stop-color="#7C3AED" />
                        <stop offset="100%" stop-color="#2563EB" />
                    </linearGradient>
                </defs>
            </svg>
            <span class="am-setup-brand-name">Auth Manager</span>
        </div>
    </header>

    <main class="am-setup-main">
        @Body
    </main>

    <footer class="am-setup-footer">
        <span>DotNetAuthManager · <a href="https://github.com/dotnetappdev/authmanager" target="_blank" rel="noopener">Docs &amp; GitHub</a></span>
    </footer>
</div>

@code {
    private readonly MudTheme _theme = AuthManagerThemeProvider.Build();
}
