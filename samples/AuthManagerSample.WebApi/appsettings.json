{
  "ConnectionStrings": {
    "Default": "Data Source=webapi.db"
  },
  "Jwt": {
    "SecretKey": "change-this-to-a-long-random-secret-key-in-production-min-32-chars",
    "Issuer": "https://localhost:5001",
    "Audience": "https://localhost:5001",
    "AccessTokenExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
