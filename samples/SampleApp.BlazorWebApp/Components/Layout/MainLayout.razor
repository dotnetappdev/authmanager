@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">My App</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-3">@context.User.Identity!.Name</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="/account/logout" Title="Sign out" />
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/account/login" Color="Color.Inherit" Variant="Variant.Text">Sign In</MudButton>
                <MudButton Href="/account/register" Color="Color.Inherit" Variant="Variant.Text">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
        <MudIconButton Icon="@(IsDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigation</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-6 pb-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;

    private bool IsDark => _isDark;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme()  => _isDark = !_isDark;
}
